{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://niyanta.example.com/schemas/dataconnector/connector-connection.schema.json",
  "title": "ConnectorConnection",
  "description": "A tenant-specific instance of a connector definition. Secrets are references only.",
  "type": "object",
  "required": ["definition_id", "definition_version", "name", "destination"],
  "additionalProperties": true,
  "properties": {
    "id": { "type": "string" },
    "customer_id": { "type": "string" },
    "definition_id": { "type": "string" },
    "definition_version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "name": { "type": "string", "minLength": 1 },
    "status": { "type": "string", "enum": ["configured", "enabled", "disabled", "paused", "quarantined"] },
    "config": { "type": "object" },
    "secret_refs": {
      "type": "object",
      "description": "Map of field -> secret reference URI. Raw secrets are forbidden.",
      "additionalProperties": { "type": "string", "pattern": "^secret://" }
    },
    "destination": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": { "type": "string" },
        "endpoint_ref": { "type": "string" }
      }
    },
    "isolation": {
      "type": "object",
      "properties": {
        "level": { "type": "string", "enum": ["shared", "pooled", "dedicated"] },
        "worker_pool": { "type": "string" }
      }
    }
  }
}
