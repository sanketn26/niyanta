{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://niyanta.example.com/schemas/dataconnector/connector-definition.schema.json",
  "title": "ConnectorDefinition",
  "description": "A versioned, tenant-independent connector template. See DATA_CONNECTOR_SPEC.md.",
  "type": "object",
  "required": ["id", "version", "kind", "direction", "display", "packaging", "compatibility"],
  "additionalProperties": true,
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z0-9_]+$" },
    "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "kind": {
      "type": "string",
      "enum": ["poll_http", "push_http", "object_store", "database_source", "cdc_source",
               "stream_listener", "stream_subscription", "worker_plugin", "batch_import", "destination_connector"]
    },
    "direction": { "type": "string", "enum": ["source", "destination", "source_and_destination"] },
    "display": {
      "type": "object",
      "required": ["title"],
      "properties": {
        "title": { "type": "string" },
        "publisher": { "type": "string" },
        "description": { "type": "string" },
        "logo_ref": { "type": "string" },
        "docs_url": { "type": "string", "format": "uri" }
      }
    },
    "capabilities": { "type": "array", "items": { "type": "string" } },
    "isolation": {
      "type": "object",
      "properties": {
        "minimum_level": { "type": "string", "enum": ["shared", "pooled", "dedicated"] },
        "allowed_levels": { "type": "array", "items": { "type": "string", "enum": ["shared", "pooled", "dedicated"] } },
        "state_scope": { "type": "string" },
        "secret_scope": { "type": "string" },
        "max_connections_per_worker": { "type": "integer", "minimum": 1 }
      }
    },
    "packaging": {
      "type": "object",
      "required": ["mode"],
      "properties": {
        "mode": { "type": "string", "enum": ["declarative", "native_plugin", "oci_image", "external_command", "airbyte_manifest", "airbyte_image"] },
        "runtime": { "type": ["string", "null"] },
        "image": { "type": ["string", "null"] },
        "allowed_hosts": { "type": "array", "items": { "type": "string" } }
      }
    },
    "compatibility": {
      "type": "object",
      "properties": {
        "protocol": { "type": "string" },
        "protocol_version": { "type": "string" },
        "imported_from": { "type": ["string", "null"] }
      }
    }
  }
}
