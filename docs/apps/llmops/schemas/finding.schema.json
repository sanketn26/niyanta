{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://niyanta.example.com/schemas/llmops/finding.schema.json",
  "title": "Finding",
  "description": "Structured, validated output of a diagnosis. The model response must parse to this shape or the diagnosis attempt fails (no malformed findings). Evidence carries references only — never raw payloads.",
  "type": "object",
  "required": ["issue_category", "confidence", "root_cause", "evidence"],
  "additionalProperties": true,
  "properties": {
    "id": { "type": "string" },
    "connection_id": { "type": "string" },
    "diagnosis_run_id": { "type": "string" },
    "issue_category": {
      "type": "string",
      "enum": ["auth_failure", "source_rate_limited", "source_outage", "parser_drop_storm",
               "destination_failure", "lag_growth", "checkpoint_stall", "config_drift", "unknown"]
    },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "root_cause": { "type": "string", "minLength": 1 },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "ref"],
        "properties": {
          "type": { "type": "string", "enum": ["ingestion_event", "metric", "run", "control"] },
          "ref": { "type": "string" },
          "window": { "type": "string" }
        }
      }
    },
    "suggested_action": {
      "type": "object",
      "properties": {
        "control_type": { "type": "string", "enum": ["rate_limit_override", "temporary_disable", "pause", "resume", "quarantine"] },
        "config": { "type": "object" }
      }
    },
    "auto_actionable": {
      "type": "boolean",
      "description": "Computed by the guardrail evaluator, NOT taken from the model output."
    }
  }
}
