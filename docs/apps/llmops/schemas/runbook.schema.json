{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://niyanta.example.com/schemas/llmops/runbook.schema.json",
  "title": "LLMOpsRunbook",
  "description": "Declarative runbook: trigger -> diagnosis intent -> guarded responses -> verification. Interpreted by the sweep/diagnose/remediate activities. See LLMOPS_SPEC.md.",
  "type": "object",
  "required": ["id", "scope", "when", "diagnose", "respond"],
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string" },
    "scope": { "type": "string", "enum": ["connector_definition", "tenant_private"] },
    "connector_definition_id": { "type": ["string", "null"] },
    "enabled": { "type": "boolean", "default": true },
    "when": {
      "type": "object",
      "description": "Trigger predicate over Data Connector telemetry.",
      "properties": {
        "any_of": { "type": "array", "items": { "$ref": "#/$defs/predicate" } },
        "all_of": { "type": "array", "items": { "$ref": "#/$defs/predicate" } }
      }
    },
    "diagnose": {
      "type": "object",
      "required": ["intent"],
      "properties": {
        "intent": { "type": "string" },
        "context": { "type": "array", "items": { "type": "object" } },
        "min_confidence": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "respond": {
      "type": "array",
      "items": { "$ref": "#/$defs/response" }
    }
  },
  "$defs": {
    "predicate": {
      "type": "object",
      "properties": {
        "significant_event": { "type": "string" },
        "metric": { "type": "string" },
        "over": { "type": "string" },
        "above": { "type": "number" },
        "below": { "type": "number" },
        "health_transition": { "type": "string" }
      }
    },
    "response": {
      "type": "object",
      "properties": {
        "if": {
          "type": "object",
          "properties": {
            "issue_category": { "type": "string" },
            "confidence_gte": { "type": "number", "minimum": 0, "maximum": 1 }
          }
        },
        "else": { "type": ["boolean", "object"] },
        "action": {
          "type": "object",
          "required": ["control_type"],
          "properties": {
            "control_type": { "type": "string", "enum": ["rate_limit_override", "temporary_disable", "pause", "resume", "quarantine"] },
            "config": { "type": "object" }
          }
        },
        "mode": { "type": "string", "enum": ["auto", "suggest"] },
        "verify_after_seconds": { "type": "integer", "minimum": 0 },
        "on_no_improvement": { "type": "string", "enum": ["rollback", "escalate", "retry_with"] }
      }
    }
  }
}
